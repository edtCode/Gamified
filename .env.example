# Copy this file to .env at the repo root: cp .env.example .env
# The API loads variables from the repo-root .env.

# --- Database (matches docker-compose.yml) ---
DATABASE_URL="postgresql://gamified:gamified@localhost:5544/gamified?schema=public"

# --- Redis (matches docker-compose.yml) ---
REDIS_URL="redis://localhost:6379"

# --- API server ---
API_PORT=4000
# Public origin of the web app, used for CORS and for building email-verification links.
WEB_ORIGIN="http://localhost:3000"

# --- Auth ---
JWT_SECRET="dev-change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- College email verification ---
# Comma-separated list of allowed college email domains for signup.
ALLOWED_EMAIL_DOMAINS="example.edu"
# In dev, verification links are printed to the API console instead of being emailed.

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
